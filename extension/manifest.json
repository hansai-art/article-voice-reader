{
  "manifest_version": 3,
  "name": "語音朗讀器 — Article Voice Reader",
  "version": "1.0.0",
  "description": "Send any web article to Article Voice Reader for text-to-speech playback",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.svg"
    }
  },
  "icons": {
    "48": "icon-48.svg",
    "128": "icon-48.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
